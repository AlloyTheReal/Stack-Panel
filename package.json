{
  "name": "stackpanel",
  "icon": "icone.png",
  "version": "2.0.0",
  "description": "Minecraft Server Manager",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "vite",
    "electron": "vite build && electron .",
    "electron:pack": "vite build && electron-builder",
    "electron:pack:linux": "vite build && electron-builder --linux --publish never",
    "electron:pack:mac": "vite build && electron-builder --mac --publish never",
    "electron:pack:win": "vite build && electron-builder --win --publish never",
    "electron:pack:all": "vite build && electron-builder -wml --publish never",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.alloy.stackpanel",
    "productName": "Stack Panel",
    "win": {
      "icon": "icone.png"
    },
    "linux": {
      "icon": "icone.png"
    },
    "mac": {
      "icon": "icone.png"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "electron-squirrel-startup": "^1.0.1",
    "pidtree": "^0.6.0",
    "pidusage": "^4.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.2.4"
  },
  "keywords": []
}